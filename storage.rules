rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Voice reference recordings for custom coach
    // Path: {userId}/sound-ref/{filename}
    // LINE LIFF auth is used (not Firebase Auth), so request.auth is null
    // Restrict to sound-ref path only, max 5MB WAV files
    match /{userId}/sound-ref/{fileName} {
      allow read: if true;
      allow write: if request.resource == null // allow delete
                   || (request.resource.size < 5 * 1024 * 1024
                       && request.resource.contentType.matches('audio/.*'));
    }

    // Nutrition scan images
    // Path: nutrition-scans/...
    // Allow read (and list) for anyone
    match /nutrition-scans/{allPaths=**} {
      allow read: if true;
    }
    // Allow write for images up to 10MB
    match /nutrition-scans/{userId}/{fileName} {
      allow write: if request.resource == null // allow delete
                   || (request.resource.size < 10 * 1024 * 1024
                       && request.resource.contentType.matches('image/.*'));
    }

    // Workout share card images
    // Path: workout-shares/...
    // Allow read (and list) for anyone
    match /workout-shares/{allPaths=**} {
      allow read: if true;
    }
    // Allow write for images up to 5MB
    match /workout-shares/{userId}/{fileName} {
      allow write: if request.resource == null
                   || (request.resource.size < 5 * 1024 * 1024
                       && request.resource.contentType.matches('image/.*'));
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
